{
  "name": "delidev-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build && node scripts/postbuild.mjs",
    "dev": "rsbuild dev",
    "icons": "node scripts/generate-icons.mjs",
    "lint": "eslint . --max-warnings 0",
    "preview": "rsbuild preview",
    "pretest": "pnpm --filter @delinoio/delibase-connect build",
    "test": "vitest run",
    "test:a11y": "vitest run src/test/accessibility.test.tsx",
    "test:browser": "playwright test",
    "test:browser:chromium": "playwright test --project=chromium",
    "test:pwa": "vitest run src/test/cache-policy.test.ts && node scripts/validate-artifact.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.13.0",
    "@connectrpc/connect": "2.1.2",
    "@connectrpc/connect-query": "2.2.0",
    "@connectrpc/connect-web": "2.1.2",
    "@delinoio/delibase-connect": "workspace:*",
    "@logto/browser": "3.0.13",
    "@logto/react": "4.0.14",
    "@tanstack/react-query": "5.101.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.61.1",
    "@rsbuild/core": "2.1.7",
    "@rsbuild/plugin-react": "2.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "@vitest/coverage-v8": "4.1.0",
    "axe-core": "4.11.1",
    "eslint": "9.39.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "17.4.0",
    "jsdom": "28.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
