# Optional overrides for runtime transport selection.
# EXPO_PUBLIC_MPAPP_HID_TRANSPORT_MODE=native-android-hid
# EXPO_PUBLIC_MPAPP_HID_TRANSPORT_MODE=stub

# Optional override for native HID target host.
# EXPO_PUBLIC_MPAPP_HID_TARGET_HOST_ADDRESS=192.168.0.10

# Optional screen contract override.
# EXPO_PUBLIC_MPAPP_SCREEN_ID=main-console
