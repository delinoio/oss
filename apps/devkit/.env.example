# Commit Tracker proxy defaults
COMMIT_TRACKER_SERVER_URL=http://127.0.0.1:8091
COMMIT_TRACKER_WEB_TOKEN=ct-token
COMMIT_TRACKER_WEB_SUBJECT=ct-token

# Optional public fallbacks
# NEXT_PUBLIC_COMMIT_TRACKER_SERVER_URL=http://127.0.0.1:8091
# NEXT_PUBLIC_COMMIT_TRACKER_TOKEN=ct-token
# NEXT_PUBLIC_COMMIT_TRACKER_SUBJECT=ct-token

# Thenv proxy defaults
THENV_SERVER_URL=http://127.0.0.1:8087
THENV_WEB_TOKEN=admin
THENV_WEB_SUBJECT=admin

# Optional public fallbacks
# NEXT_PUBLIC_THENV_SERVER_URL=http://127.0.0.1:8087
# NEXT_PUBLIC_THENV_TOKEN=admin
# NEXT_PUBLIC_THENV_SUBJECT=admin
