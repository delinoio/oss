{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DexDex",
  "version": "0.1.0",
  "identifier": "io.delino.dexdex",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5991",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DexDex",
        "width": 1200,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
